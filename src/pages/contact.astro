---
import Layout from '../layouts/Layout.astro';
import RPGPanel from '../components/RPGPanel.astro';

const socials = [
  { label: 'GitHub', href: 'https://github.com/joonkim' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/joonkim' },
  { label: 'Email', href: 'mailto:hello@joonkim.dev' },
];
---

<Layout title="Guild Hall | Contact">
  <main class="min-h-screen bg-[radial-gradient(circle_at_top,_#4a2c2c_0%,_#211a2b_50%,_#100d15_100%)] px-4 pb-16 pt-24">
    <section class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-[1fr_1.2fr]">
      <RPGPanel title="Guild Hall">
        <p class="text-xl leading-relaxed text-parchment/85">
          Post a request on the board. I usually reply within 2-3 days.
        </p>
        <div class="mt-5 space-y-3">
          {socials.map((social) => (
            <a
              href={social.href}
              target={social.href.startsWith('http') ? '_blank' : undefined}
              rel={social.href.startsWith('http') ? 'noreferrer' : undefined}
              class="block rounded border border-panel-light/70 bg-panel-dark/55 px-3 py-2 text-xl text-gold/90 hover:text-gold transition-colors"
            >
              {social.label}
            </a>
          ))}
        </div>
      </RPGPanel>

      <RPGPanel title="Post A Request">
        <form id="contact-form" class="grid gap-4" method="post" action="/api/contact">
          <label class="grid gap-1">
            <span class="font-pixel text-[10px] uppercase tracking-wide text-parchment/70">Name</span>
            <input
              class="rounded border-2 border-panel-light/70 bg-panel-dark/70 px-3 py-2 text-xl text-parchment outline-none focus:border-gold"
              name="name"
              required
              maxlength="80"
            />
          </label>

          <label class="grid gap-1">
            <span class="font-pixel text-[10px] uppercase tracking-wide text-parchment/70">Email (Optional)</span>
            <input
              class="rounded border-2 border-panel-light/70 bg-panel-dark/70 px-3 py-2 text-xl text-parchment outline-none focus:border-gold"
              name="email"
              type="email"
              maxlength="120"
            />
          </label>

          <label class="grid gap-1">
            <span class="font-pixel text-[10px] uppercase tracking-wide text-parchment/70">Subject</span>
            <select
              class="rounded border-2 border-panel-light/70 bg-panel-dark/70 px-3 py-2 text-xl text-parchment outline-none focus:border-gold"
              name="subject"
              required
            >
              <option value="Job Opportunity">Job Opportunity</option>
              <option value="Collaboration">Collaboration</option>
              <option value="Just saying hi">Just saying hi</option>
              <option value="Other">Other</option>
            </select>
          </label>

          <label class="grid gap-1">
            <span class="font-pixel text-[10px] uppercase tracking-wide text-parchment/70">Message</span>
            <textarea
              class="min-h-36 rounded border-2 border-panel-light/70 bg-panel-dark/70 px-3 py-2 text-xl text-parchment outline-none focus:border-gold"
              name="message"
              required
              maxlength="3000"
            ></textarea>
          </label>

          <input name="company" class="hidden" tabindex="-1" autocomplete="off" />

          <button
            class="font-pixel text-[10px] uppercase tracking-wide rounded border-2 border-gold-dim bg-gold/20 px-4 py-3 text-gold hover:bg-gold/30 transition-colors"
            type="submit"
          >
            Submit Quest
          </button>
        </form>
        <p id="form-status" class="mt-3 text-xl text-parchment/70" aria-live="polite"></p>
      </RPGPanel>
    </section>
  </main>
</Layout>

<script is:inline>
  const form = document.getElementById('contact-form');
  const statusEl = document.getElementById('form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]');
    if (!submitBtn || !(submitBtn instanceof HTMLButtonElement)) return;

    const formData = new FormData(form);
    submitBtn.disabled = true;
    statusEl.textContent = 'Posting request...';

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        body: formData,
      });

      const payload = await response.json().catch(() => null);
      if (!response.ok || !payload?.success) {
        throw new Error(payload?.error || 'Failed to send');
      }

      form.reset();
      statusEl.textContent = 'Request posted. Thanks for reaching out.';
    } catch (error) {
      console.error(error);
      statusEl.textContent = 'Request failed. Please try again or email hello@joonkim.dev.';
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
