---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import RPGPanel from '../../components/RPGPanel.astro';

const categoryClass = {
  TECH: 'text-cyan',
  MIND: 'text-purple',
  BODY: 'text-bar-hp',
  MISC: 'text-orange',
} as const;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout title="Field Notes | joonkim.dev">
  <main class="min-h-screen bg-[radial-gradient(circle_at_top,_#2b294d_0%,_#1a1a2e_50%,_#0f0d1b_100%)] px-4 pb-16 pt-24">
    <section class="mx-auto max-w-5xl">
      <RPGPanel title="Field Notes">
        <div class="grid gap-4">
          {posts.map((post) => (
            <article class="rounded border-2 border-panel-light/70 bg-panel-dark/45 p-5">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <p class:list={['font-pixel text-[10px] uppercase tracking-wide', categoryClass[post.data.category]]}>
                  [{post.data.category}]
                </p>
                <p class="font-pixel text-[10px] text-parchment/60">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </p>
              </div>

              <h3 class="mt-2 font-pixel text-[11px] uppercase tracking-wide text-gold">{post.data.title}</h3>
              <p class="mt-2 text-xl leading-relaxed text-parchment/85">{post.data.description}</p>

              <a
                href={`/blog/${post.id}`}
                class="mt-3 inline-block text-lg text-cyan/90 hover:text-cyan transition-colors"
              >
                Read entry →
              </a>
            </article>
          ))}
        </div>
      </RPGPanel>
    </section>
  </main>
</Layout>
